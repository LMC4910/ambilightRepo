{
  "name": "ambilight-desktop",
  "productName": "Ambilight Desktop",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "author": "Ambilight Desktop",
  "description": "Cross-platform ambient lighting platform for MagicHome LED controllers.",
  "homepage": "https://github.com/ambilight-desktop/ambilight",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "sync:version": "node ../scripts/sync-version.mjs",
    "gen:icons": "node scripts/gen-icons.mjs",
    "build": "vite build",
    "electron:build": "pnpm run sync:version && pnpm run gen:icons && vite build && electron-builder --win",
    "dist:win": "pnpm run sync:version && pnpm run gen:icons && vite build && electron-builder --win",
    "dist:mac": "pnpm run sync:version && pnpm run gen:icons && vite build && electron-builder --mac",
    "dist:linux": "pnpm run sync:version && pnpm run gen:icons && vite build && electron-builder --linux",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.ambilight.desktop",
    "productName": "Ambilight Desktop",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "electronLanguages": [
      "en-US"
    ],
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "../dist/service/ambilight-service",
        "to": "service",
        "filter": [
          "**/*"
        ]
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "LMC4910",
      "repo": "ambilightRepo",
      "releaseType": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png",
      "verifyUpdateCodeSignature": true
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Ambilight Desktop",
      "include": "installer/nsis_hooks.nsh"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities",
      "icon": "build/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "icon": "build/icon.png",
      "maintainer": "Ambilight Desktop"
    }
  },
  "comment": "Only runtime requires of electron/main.cjs belong in dependencies; React/lucide/zustand/fontsource are bundled into dist by Vite and live in devDependencies so electron-builder doesn't pack them. Build-script approvals (onlyBuiltDependencies) live in pnpm-workspace.yaml as required by pnpm v11+.",
  "dependencies": {
    "electron-updater": "^6.6.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fontsource/inter": "^5.1.0",
    "@fontsource/jetbrains-mono": "^5.1.0",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "lucide-react": "^1.17.0",
    "postcss": "^8.5.15",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sharp": "^0.34.2",
    "zustand": "^5.0.14",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.12",
    "vite-plugin-electron": "^1.0.0",
    "wait-on": "^9.0.10"
  }
}
