{
  "capture": {
    "method": "wgc",
    "monitor_index": 3,
    "fps_target": 30,
    "analysis_width": 80,
    "analysis_height": 45,
    "hdr": {
      "mode": "auto",
      "exposure": 1.0,
      "contrast": 1.15,
      "saturation_recovery": 1.5
    }
  },
  "device": {
    "ip": "192.168.1.29",
    "port": 5577,
    "mac": "30:3a:29:00:0c:00",
    "subnet": "192.168.1.",
    "connect_timeout": 2.0,
    "send_timeout": 1.0,
    "reconnect_interval": 5.0,
    "discovery_timeout": 0.5,
    "cache_file": "device_cache.json"
  },
  "zones": {
    "top": 7,
    "bottom": 7,
    "left": 4,
    "right": 4
  },
  "color": {
    "mode": "saturation_weighted",
    "kmeans_clusters": 3,
    "ignore_black_threshold": 30,
    "ignore_white_threshold": 225,
    "saturation_weight_power": 2.0,
    "min_saturation": 0.05,
    "vibrance": 1.35
  },
  "smoothing": {
    "enabled": true,
    "base_alpha": 0.30,
    "adaptive_fast_threshold": 30,
    "adaptive_fast_alpha": 0.80,
    "min_change": 2
  },
  "gpu": {
    "enabled": true,
    "prefer": "cupy",
    "fallback_to_cpu": true
  },
  "logging": {
    "level": "INFO",
    "file_level": "INFO",
    "file": "logs/ambilight.log",
    "max_bytes": 20971520,
    "backup_count": 10,
    "show_fps": true,
    "fps_interval": 5.0
  }
}
