# Application specific (runtime artifacts only)
# The real runtime data dir is ~/.ambilight (outside the repo). These cover the
# files the service may drop next to itself when run from the repo in dev.
# IMPORTANT: do NOT use a blanket "*.json" here — it would ignore source files
# like profiles/*.json and ui/package.json. configuration.yaml is the bundled
# default seed (build.py ships it) and must stay tracked.
logs/
device_cache.json
metrics/
auth_token
onboarded
service.out.log

# PyInstaller leftovers occasionally written at the repo root
*.spec.bak

# Native helper build output (CMake); the sources under native/ are tracked
native/build/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

